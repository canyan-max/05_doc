n&gt;&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;box-sizing: border-box; border: 0px solid oklch(0.923 0.003 48.717); margin: 0px; padding: 0px; outline-color: oklab(0.716081 0.00506151 0.00754315 / 0.5); background: 0px 0px; color: rgb(201, 145, 0);&quot; class=&quot;token macro property&quot;&gt;&lt;span style=&quot;box-sizing: border-box; border: 0px solid oklch(0.923 0.003 48.717); margin: 0px; padding: 0px; outline-color: oklab(0.716081 0.00506151 0.00754315 / 0.5); background: 0px 0px;&quot; class=&quot;token directive-hash&quot;&gt;#&lt;/span&gt;&lt;span style=&quot;box-sizing: border-box; border: 0px solid oklch(0.923 0.003 48.717); margin: 0px; padding: 0px; outline-color: oklab(0.716081 0.00506151 0.00754315 / 0.5); background: 0px 0px; color: rgb(177, 94, 242);&quot; class=&quot;token directive keyword&quot;&gt;define&lt;/span&gt; &lt;span style=&quot;box-sizing: border-box; border: 0px solid oklch(0.923 0.003 48.717); margin: 0px; padding: 0px; outline-color: oklab(0.716081 0.00506151 0.00754315 / 0.5); background: 0px 0px;&quot; class=&quot;token macro-name&quot;&gt;configTIMER_QUEUE_LENGTH&lt;/span&gt;    &lt;span style=&quot;box-sizing: border-box; border: 0px solid oklch(0.923 0.003 48.717); margin: 0px; padding: 0px; outline-color: oklab(0.716081 0.00506151 0.00754315 / 0.5); background: 0px 0px;&quot; class=&quot;token expression&quot;&gt;&lt;span style=&quot;box-sizing: border-box; border: 0px solid oklch(0.923 0.003 48.717); margin: 0px; padding: 0px; outline-color: oklab(0.716081 0.00506151 0.00754315 / 0.5); background: 0px 0px; color: rgb(229, 69, 149);&quot; class=&quot;token number&quot;&gt;10&lt;/span&gt;             &lt;/span&gt;&lt;span style=&quot;box-sizing: border-box; border: 0px solid oklch(0.923 0.003 48.717); margin: 0px; padding: 0px; outline-color: oklab(0.716081 0.00506151 0.00754315 / 0.5); background: 0px 0px; color: rgba(0, 0, 0, 0.45);&quot; class=&quot;token comment&quot;&gt;// 定时器命令队列长度&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&