        <mxCell id="pkg7jA9xBUTU1gesx26H-16" value="Instructions" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontColor=#46495D;fontFamily=Lucida Console;fontSize=15;fontStyle=1;labelBorderColor=none;" parent="1" vertex="1">
