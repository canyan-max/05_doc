        <mxCell id="MMZR0ORwyoNjBQBUhfBw-24" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry y="2760" width="580" height="298.65" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-25" value="上图就是由map文件提供，map文件主要告诉开发者,处于上面的什么段，从哪里来，被定位到ram的什么地址，以及他所占的ram大小" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;align=left;" vertex="1" parent="1">
          <mxGeometry y="3058.65" width="820" height="140" as="geometry" />
