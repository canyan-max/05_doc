        <mxCell id="eFr7Zaas-XlTVKmNe5eP-4" value="API:&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;BaseType_t ret1 = pdPASS ;&lt;/span&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; ret1 = xTaskCreate(a_task, \&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&quot;a_task&quot;, \&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;128, \&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;NULL, \&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;1, \&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;amp;a_task_handler \&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;);&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="171.5" y="2417" width="434" height="149" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-5" value="先不考虑失败的情况只考虑成功流程解析和动态任务创建" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="244" y="2388" width="330" height="29" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-10" value="" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startSize=14;endArrow=open;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;" parent="1" source="eFr7Zaas-XlTVKmNe5eP-8" target="eFr7Zaas-XlTVKmNe5eP-9" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-8" value="为任务a_task申请内存,用户传入的大小&lt;div&gt;转换128*4 = 512字节&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="171.5" y="2604" width="194" height="60" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-14" value="" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startSize=14;endArrow=open;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;" parent="1" source="eFr7Zaas-XlTVKmNe5eP-9" target="eFr7Zaas-XlTVKmNe5eP-13" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-9" value="为TCB申请内存&lt;div&gt;注意他和任务的内存是相互独立的&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="171.5" y="2702" width="194" height="60" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-18" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startSize=14;endArrow=open;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;" parent="1" source="eFr7Zaas-XlTVKmNe5eP-13" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="409" y="2897.3999938964844" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-13" value="prvInitialiseNewTask&lt;div&gt;这个函数很重要,主要是初始化任务的参数，将申请的任务内存栈底部挂再到TCB结构体,StackTOP和statck,同时把&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;a_task函数地址挂载到申请的栈空间顶部附近&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="171.5" y="2794" width="475" height="69" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-21" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startSize=14;endArrow=open;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;" parent="1" source="eFr7Zaas-XlTVKmNe5eP-15" target="eFr7Zaas-XlTVKmNe5eP-20" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-15" value="prvAddNewTaskToReadyList&lt;div&gt;把当前的tcb结构体挂入到调度链表等待系统启动和调度&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="172" y="3076" width="475" height="69" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-19" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;startSize=14;endArrow=open;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;" parent="1" source="eFr7Zaas-XlTVKmNe5eP-17" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="405.5" y="3076.6000366210938" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-17" value="pxPortInitialiseStack&lt;div&gt;这里就是吧CORTEXM内核寄存器保存到任务堆栈顶部依次递减&lt;/div&gt;&lt;div&gt;R0~R15&lt;/div&gt;&lt;div&gt;a_task函数入口地址&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="168" y="2906" width="475" height="69" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-20" value="pxCurrentTCB&lt;div&gt;这个是全局头链表，主要把TCB结构体挂载上去，如果他不是NULL使用尾插法，根据优先级判断依次将创建的任务挂载在后面&lt;/div&gt;&lt;div&gt;调度主要依靠下面这些变量&lt;/div&gt;&lt;div&gt;&lt;div&gt;pxCurrentTCB = NULL;//指向当前任务&lt;/div&gt;&lt;div&gt;pxReadyTasksLists&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;xDelayedTaskList1&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;xDelayedTaskList2&lt;/span&gt;&lt;/div&gt;&lt;div&gt;在没有预期干扰的情况下同优先级任务先创建先运行&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="158" y="3204" width="503" height="148" as="geometry" />
        </mxCell>
        <mxCell id="eFr7Zaas-XlTVKmNe5eP-22" value="最主要的是&lt;span style=&quot;color: rgb(56, 58, 66); font-family: Menlo, Monaco, Consolas, &amp;quot;Cascadia Mono&amp;quot;, &amp;quot;Ubuntu Mono&amp;quot;, &amp;quot;DejaVu Sans Mono&amp;quot;, &amp;quot;Liberation Mono&amp;quot;, &amp;quot;JetBrains Mono&amp;quot;, &amp;quot;Fira Code&amp;quot;, Cousine, &amp;quot;Roboto Mono&amp;quot;, &amp;quot;Courier New&amp;quot;, Courier, sans-serif, system-ui; font-size: 13px; text-align: start; background-color: transparent;&quot;&gt;是一个双向链表&lt;/span&gt;&lt;div&gt;&lt;pre style=&quot;font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-size-adjust: none; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-variant-position: normal; font-variant-emoji: normal; font-stretch: normal; font-size: 13px; line-height: 22px; font-family: Menlo, Monaco, Consolas, &amp;quot;Cascadia Mono&amp;quot;, &amp;quot;Ubuntu Mono&amp;quot;, &amp;quot;DejaVu Sans Mono&amp;quot;, &amp;quot;Liberation Mono&amp;quot;, &amp;quot;JetBrains Mono&amp;quot;, &amp;quot;Fira Code&amp;quot;, Cousine, &amp;quot;Roboto Mono&amp;quot;, &amp;quot;Courier New&amp;quot;, Courier, sans-serif, system-ui; overflow: auto; text-wrap-mode: wrap; word-break: break-all; padding: 16px; color: rgb(15, 17, 21); text-align: start; margin-top: 0px !important; margin-bottom: 0px !important;&quot;&gt;&lt;span style=&quot;color: rgb(166, 38, 164);&quot; class=&quot;token keyword&quot;&gt;struct&lt;/span&gt; &lt;span style=&quot;color: rgb(183, 107, 1);&quot; class=&quot;token class-name&quot;&gt;xLIST_ITEM&lt;/span&gt; &lt;span style=&quot;color: rgb(56, 58, 66);&quot; class=&quot;token punctuation&quot;&gt;{&lt;/span&gt;&lt;br&gt;    TickType_t xItemValue&lt;span style=&quot;color: rgb(56, 58, 66);&quot; class=&quot;token punctuation&quot;&gt;;&lt;/span&gt;     &lt;span style=&quot;color: rgb(160, 161, 167); font-style: italic;&quot; class=&quot;token comment&quot;&gt;// 衍生1：排序值（优先级/延时时间）&lt;/span&gt;&lt;br&gt;    &lt;span style=&quot;color: rgb(166, 38, 164);&quot; class=&quot;token keyword&quot;&gt;struct&lt;/span&gt; &lt;span style=&quot;color: rgb(183, 107, 1);&quot; class=&quot;token class-name&quot;&gt;xLIST_ITEM&lt;/span&gt; &lt;span style=&quot;color: rgb(64, 120, 242);&quot; class=&quot;token operator&quot;&gt;*&lt;/span&gt;pxNext&lt;span style=&quot;color: rgb(56, 58, 66);&quot; class=&quot;token punctuation&quot;&gt;;&lt;/span&gt;&lt;br&gt;    &lt;span style=&quot;color: rgb(166, 38, 164);&quot; class=&quot;token keyword&quot;&gt;struct&lt;/span&gt; &lt;span style=&quot;color: rgb(183, 107, 1);&quot; class=&quot;token class-name&quot;&gt;xLIST_ITEM&lt;/span&gt; &lt;span style=&quot;color: rgb(64, 120, 242);&quot; class=&quot;token operator&quot;&gt;*&lt;/span&gt;pxPrevious&lt;span style=&quot;color: rgb(56, 58, 66);&quot; class=&quot;token punctuation&quot;&gt;;&lt;/span&gt;&lt;br&gt;    &lt;span style=&quot;color: rgb(166, 38, 164);&quot; class=&quot;token keyword&quot;&gt;void&lt;/span&gt; &lt;span style=&quot;color: rgb(64, 120, 242);&quot; class=&quot;token operator&quot;&gt;*&lt;/span&gt;pvOwner&lt;span style=&quot;color: rgb(56, 58, 66);&quot; class=&quot;token punctuation&quot;&gt;;&lt;/span&gt;              &lt;span style=&quot;color: rgb(160, 161, 167); font-style: italic;&quot; class=&quot;token comment&quot;&gt;// 衍生2：指向拥有者（TCB）&lt;/span&gt;&lt;br&gt;    &lt;span style=&quot;color: rgb(166, 38, 164);&quot; class=&quot;token keyword&quot;&gt;void&lt;/span&gt; &lt;span style=&quot;color: rgb(64, 120, 242);&quot; class=&quot;token operator&quot;&gt;*&lt;/span&gt;pvContainer&lt;span style=&quot;color: rgb(56, 58, 66);&quot; class=&quot;token punctuation&quot;&gt;;&lt;/span&gt;          &lt;span style=&quot;color: rgb(160, 161, 167); font-style: italic;&quot; class=&quot;token comment&quot;&gt;// 衍生3：指向所属链表&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(56, 58, 66);&quot; class=&quot;token punctuation&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: rgb(56, 58, 66);&quot; class=&quot;token punctuation&quot;&gt;;&lt;/span&gt;&lt;/pre&gt;&lt;pre style=&quot;font-variant-numeric: normal; font-variant-east-asian: normal; font-variant-alternates: normal; font-size-adjust: none; font-kerning: auto; font-optical-sizing: auto; font-feature-settings: normal; font-variation-settings: normal; font-variant-position: normal; font-variant-emoji: normal; font-stretch: normal; font-size: 13px; line-height: 22px; font-family: Menlo, Monaco, Consolas, &amp;quot;Cascadia Mono&amp;quot;, &amp;quot;Ubuntu Mono&amp;quot;, &amp;quot;DejaVu Sans Mono&amp;quot;, &amp;quot;Liberation Mono&amp;quot;, &amp;quot;JetBrains Mono&amp;quot;, &amp;quot;Fira Code&amp;quot;, Cousine, &amp;quot;Roboto Mono&amp;quot;, &amp;quot;Courier New&amp;quot;, Courier, sans-serif, system-ui; overflow: auto; text-wrap-mode: wrap; word-break: break-all; padding: 16px; text-align: start; margin-top: 0px !important; margin-bottom: 0px !important; color: rgb(15, 17, 21);&quot;&gt;&lt;br&gt;&lt;/pre&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="13" y="3522" width="734" height="225" as="geometry" />
        </mxCell>
        <mxCell id="B2B8hOsv_4OnOvRm1zbt-2" value="RTOS的调度策略" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="6" y="3781" width="454" height="93" as="geometry" />
        </mxCell>
        <mxCell id="B2B8hOsv_4OnOvRm1zbt-3" value="抢占式+时间片轮转&lt;div&gt;什么是抢占：高优先级可以抢占低优先级&lt;/div&gt;&lt;div&gt;时间片轮转：达到1ms后将会切换任务,同优先级&lt;/div&gt;&lt;div&gt;如果是合作式那么,需要同优先级任务主动让出时间片&lt;/div&gt;&lt;div&gt;缺点高优先级任务不放弃低优先级无法执行，因为调度器总是选择高优先级任务运行&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="71" y="3878" width="454" height="93" as="geometry" />
        </mxCell>
        <mxCell id="SCLOx2xJq0SCQwxIlIV8-1" value="rtos-任务主要2个状态&lt;div&gt;运行态&lt;/div&gt;&lt;div&gt;非运行态-&amp;gt;阻塞态，挂起态，就绪态&lt;/div&gt;&lt;div&gt;而且RTOS必须保证一个任务在运行，所以才有了idletask-&amp;gt;最低优先级的任务0&lt;/div&gt;&lt;div&gt;就绪态-&amp;gt;任务没有实际运行并且也没有被阻塞或挂起，在等待调度器来选这个任务运行&lt;/div&gt;" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="178.5" y="4016" width="454" height="93" as="geometry" />
        </mxCell>
        <mxCell id="lRMUmvbayZdvGjP5ZWLq-2" value="&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;有关任务的基本API&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(127, 132, 142); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space-collapse: preserve;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; api:uxTaskPriorityGet();&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(127, 132, 142); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space-collapse: preserve;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; vTaskPrioritySet();&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(127, 132, 142); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space-collapse: preserve;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; vTaskDelete();&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(127, 132, 142); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space-collapse: preserve;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; xTaskCreate();&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(127, 132, 142); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space-collapse: preserve;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; vTaskDelay();&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(127, 132, 142); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space-collapse: preserve;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; vTaskDelayUntil();&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(127, 132, 142); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space-collapse: preserve;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; xTaskGetTickCount();&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(127, 132, 142); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space-collapse: preserve;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; vTaskSuspendAll();&lt;/span&gt;&lt;br&gt;&lt;/span&gt;&lt;div&gt;&lt;div style=&quot;color: rgb(171, 178, 191); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; line-height: 19px; white-space-collapse: preserve;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;color: rgb(127, 132, 142); background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; xTaskResumeAll();&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="0.54" y="4210" width="387" height="180" as="geometry" />
        </mxCell>
        <mxCell id="lRMUmvbayZdvGjP5ZWLq-3" value="rtos的队列" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="1015" y="22" width="351" height="69" as="geometry" />
        </mxCell>
        <mxCell id="lRMUmvbayZdvGjP5ZWLq-4" value="在RTOS里面的队列,都是写好的可以直接使用的API，可以从任务到任务，中断到任务，任务和中断之间都可以弄&lt;div&gt;主要是2套API 带ISR 是在中断内使用 不带ISR就是在任务中使用&lt;/div&gt;&lt;div&gt;RTOS里面的队列机制是FIFO形式,先进先出的形式,图示如下,可以通过API往队列头写或队列尾部写,当有别的任务读取了队列里面的数据，后面数据往前移动&amp;nbsp;&lt;/div&gt;&lt;div&gt;而且rtos的队列机制是字节字节复制的形式&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="834" y="103" width="725" height="92" as="geometry" />
        </mxCell>
        <mxCell id="lRMUmvbayZdvGjP5ZWLq-6" value="queue-buf" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;align=left;" parent="1" vertex="1">
