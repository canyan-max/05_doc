<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/26.1.1 Chrome/132.0.6834.210 Electron/34.3.3 Safari/537.36" version="26.1.1">
  <diagram name="CPU异常和中断" id="doWZ--KAZuVLqRDES7xJ">
    <mxGraphModel dx="1030" dy="850" grid="1" gridSize="100" guides="1" tooltips="1" connect="0" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" background="none" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="KStSb-11I_N8AqFFGBWY-7" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;中断和异常&lt;/h1&gt;&lt;div&gt;中断是指：在CPU外部（片上总线的外设）促使CPU内部而产生异常，被称之为中断。&lt;/div&gt;&lt;div&gt;异常是指：在CPU内部打断了当前的程序流。例如：int32_t A = B/0; 这里叫做异常。&lt;/div&gt;&lt;div&gt;一般来统称都叫做异常，但是要区分清楚。&lt;/div&gt;&lt;div&gt;1.CPU内部的异常是同步-会立马响应&lt;/div&gt;&lt;div&gt;2.外部中断一般都是异步-会先挂起然后CPU再去响应&lt;/div&gt;&lt;div&gt;3.内核异常有：16种-hardfault NMI Reset busFault UsafeFault 保留4 SVcall PendSV SYSTICK-&amp;gt; 以上这几种在cubemx都可以看到&lt;/div&gt;&lt;div&gt;4.外部中断异常就看这个芯片的外设情况了，一般有86种（异步的）-&amp;gt;流程是：HARDWARE INT -&amp;gt; NVIC-&amp;gt;CPU&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry y="5" width="400" height="295" as="geometry" />
        </mxCell>
        <mxCell id="KStSb-11I_N8AqFFGBWY-34" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;软件中断产生-写入的是NVIC-STIR寄存器&lt;/h1&gt;&lt;p&gt;void soft_interruput(void)&lt;/p&gt;&lt;p&gt;{&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;NVIC_SetPendingIRQ();&lt;/p&gt;&lt;p&gt;}&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry y="800" width="400" height="400" as="geometry" />
        </mxCell>
        <mxCell id="KStSb-11I_N8AqFFGBWY-36" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;寄存器映射&lt;/h1&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="400" y="800" width="400" height="222" as="geometry" />
        </mxCell>
        <mxCell id="KStSb-11I_N8AqFFGBWY-37" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;中断向量表偏移&lt;/h1&gt;&lt;div&gt;像上取整-&amp;gt;2次幂形式&lt;/div&gt;&lt;div&gt;16个内核中断+87个外部中断(主要看芯片有多少个外部中断)&lt;/div&gt;&lt;div&gt;16+87=103&lt;/div&gt;&lt;div&gt;103*4 = 412字节&lt;/div&gt;&lt;div&gt;那么就要取512字节-0x20000，不能向下兼容。否则会出错&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry y="1200" width="400" height="222" as="geometry" />
        </mxCell>
        <mxCell id="pkg7jA9xBUTU1gesx26H-1" value="CPU" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;gradientColor=none;labelBackgroundColor=none;" parent="1" vertex="1">
