        <mxCell id="qUIY60qtPC6bm2DZDDYn-7" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;APP层&lt;/b&gt;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;在协议层操作完成之后，告诉APP直接做什么事情&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry y="360" width="280" height="80" as="geometry" />
        </mxCell>
