        <mxCell id="jRde3riMwwobnZp_04T4-15" value="&lt;ul&gt;&lt;li&gt;define了一个大小 必须加括号,并且末尾增加类型&lt;/li&gt;&lt;li&gt;#define&amp;nbsp; SIZE_MAX&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;(0x1111U)&lt;/li&gt;&lt;li&gt;枚举形式的等号最好都对其&lt;/li&gt;&lt;li&gt;代码不得超过80列&lt;/li&gt;&lt;/ul&gt;" style="text;strokeColor=none;fillColor=none;html=1;whiteSpace=wrap;verticalAlign=middle;overflow=hidden;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="5" y="2394" width="627" height="113" as="geometry" />
        </mxCell>
        <mxCell id="jRde3riMwwobnZp_04T4-16" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="9" y="2526" width="789" height="298.4" as="geometry" />
        </mxCell>
        <mxCell id="jRde3riMwwobnZp_04T4-17" value="&lt;ul style=&quot;forced-color-adjust: none; orphans: 2; text-align: left; text-indent: 0px; widows: 2; background-color: rgb(251, 251, 251); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; color: rgb(0, 0, 0);&quot;&gt;&lt;li style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Lucida Console&amp;quot;; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; text-transform: none; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;命名方式均采用小写加下划线隔开,所有变量必须初始化.&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Lucida Console&amp;quot;; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; text-transform: none; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;uint8_t name_lenth = 0;&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0); font-family: &amp;quot;Lucida Console&amp;quot;; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; letter-spacing: normal; text-transform: none; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; forced-color-adjust: none;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;宏定义和枚举里面的类型需要采用大写&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0); forced-color-adjust: none;&quot;&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;#define OS_DELAY_SUPPORT&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; /*OS DELAY SUPPORT*/&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;#define BSP_LED_DEBUG_ENABLE&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;/*DEBUG MODE TO OUTPUT LOG MSG*/&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;#define BSP_LED_IS_INIT&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; (1U)&amp;nbsp; &amp;nbsp;/*THE LED IS INITIALIZED */&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;#define BSP_LED_NOT_INIT&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;(0U)&amp;nbsp; &amp;nbsp;/*THE LED NOT INITIALIZED */&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;typedef enum LED_DRIVER_STATUS_T&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;{&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; LED_DRIVER_OK&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;=&amp;nbsp; &amp;nbsp; 0x00,/* operation success&amp;nbsp; &amp;nbsp;*/&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; LED_DRIVER_ERROR&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; =&amp;nbsp; &amp;nbsp; 0x01,/* operation failed&amp;nbsp; &amp;nbsp; */&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; LED_DRIVER_PARA_ERR&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;=&amp;nbsp; &amp;nbsp; 0x02,/* parameter error&amp;nbsp; &amp;nbsp; &amp;nbsp;*/&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; LED_DRIVER_OPS_PARA_ERR&amp;nbsp; &amp;nbsp; &amp;nbsp;=&amp;nbsp; &amp;nbsp; 0x03 /* ops parameter error */&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;}led_driver_status_t;&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp;指针变量以p开头,函数指针以pf开头&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;函数指针示例&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;typedef led_driver_status_t (*pf_led_control_t)( \&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; struct BSP_LED_DRIVER_T*self&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; );&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;指针变量定义示例&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;int *p_data = null;&lt;/b&gt;&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;条件判断需要顶格子写,示例如下&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; if(NULL == p_handler_self-&amp;gt;p_os_func-&amp;gt;os_delay_ms)&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; {&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;#ifdef DEBUG_MODE&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; RTT_ELOG_DEBUG(&quot;LED_HANDLER_PARA_ERR&quot;);&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;#endif&amp;nbsp;&amp;nbsp;&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ret = LED_HANDLER_PARA_ERR;&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return ret ;&lt;/b&gt;&lt;/span&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&lt;b&gt;&am