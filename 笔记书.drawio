        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-23" value="LED1" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="90" y="1500" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-50" value="" style="triangle;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="260" y="1460" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-51" value="" style="endArrow=none;html=1;rounded=0;startSize=14;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;curved=1;" parent="1" edge="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="240" y="1480" as="sourcePoint" />
            <mxPoint x="320" y="1480" as="targetPoint" />
