        <mxCell id="jRde3riMwwobnZp_04T4-7" value="/*&#xa; * ****************************************************************************&#xa; * Copyright (C), Inc.(Gmbh) or its affiliates.&#xa; * All Rights Reserved.&#xa; * &#xa; * @file               :   bsp_led_driver.h&#xa; * &#xa; * @pardependencies    :&#xa; *                         stdint.h   &#xa; *                         bsp_led_driver.h&#xa; * &#xa; * @author             :   null&#xa; * &#xa; * @brief              :   Provide the HAL APIs of .&#xa; * &#xa; * @Processingflow     :&#xa; * &#xa; * @calldirectly       :&#xa; * &#xa; * @version            :   V1.0 &#xa; * &#xa; * @note               :   1 tab == 4 spaces!&#xa; * ****************************************************************************&#xa; */&#xa;&#xa;&#xa;/* Define to prevent recursive inclusion -------------------------------------*/&#xa;#ifndef __BSP_LED_DRIVER_H_&#xa;#define __BSP_LED_DRIVER_H_&#xa;&#xa;/* Includes ------------------------------------------------------------------*/&#xa;&#xa;/* Private includes ----------------------------------------------------------*/&#xa;&#xa;&#xa;/* Private typedef -----------------------------------------------------------*/&#xa;&#xa;/* Private define ------------------------------------------------------------*/&#xa;&#xa;/* Private variables ---------------------------------------------------------*/&#xa;&#xa;&#xa;/* Private function prototypes -----------------------------------------------*/&#xa;&#xa;&#xa;/* Exported types ------------------------------------------------------------*/&#xa;&#xa;&#xa;// &lt;&lt;&lt; led driver status definition                                 &gt;&gt;&gt;&#xa;&#xa;// &lt;&lt;&lt; end of led proportion definition                             &gt;&gt;&gt;&#xa;&#xa;&#xa;&#xa;/* Exported variables --------------------------------------------------------*/&#xa;&#xa;&#xa;/* Exported functions --------------------------------------------------------*/&#xa;&#xa;#endif /*