        <mxCell id="pkg7jA9xBUTU1gesx26H-16" value="Instructions" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
