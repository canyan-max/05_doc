        <mxCell id="FO6a5jXskNcYPXz5xM0C-16" value="R11" style="rounded=0;html=1;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fillColor=#B2C9AB;strokeColor=#788AA3;fontColor=#46495D;fontFamily=Lucida Console;fontSize=15;align=left;fontStyle=1;labelBorderColor=none;verticalAlign=top;" parent="1" vertex="1">
