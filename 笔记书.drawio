        <mxCell id="hvT5LnOeasCK2AgFjy0b-14" value="rtos的信号量" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="2569" y="31" width="351" height="69" as="geometry" />
        </mxCell>
        <mxCell id="hvT5LnOeasCK2AgFjy0b-15" value="&lt;font face=&quot;Maple Mono NF CN&quot;&gt;信号量主要分2种类型&lt;/font&gt;&lt;div&gt;&lt;font face=&quot;Maple Mono NF CN&quot;&gt;1.计数类型&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Maple Mono NF CN&quot;&gt;2.二进制类型&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Maple Mono NF CN&quot;&gt;主要区别:二进制类型的长度是1固定 计数类型可以设定长度，资源可以累计&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Maple Mono NF CN&quot;&gt;二进制信号量主要用来做任务同步个人感觉，one by one 生产好马上消费,做任务同步，比较急&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Maple Mono NF CN&quot;&gt;计数类型主要做资源管理，如果我生产速度很快一下，可以存起来 生产者慢慢使用&lt;/font&gt;&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="2489" y="83" width="725" height="272" as="geometry" />
        </mxCell>
        <mxCell id="hvT5LnOeasCK2AgFjy0b-17" value="if(NULL == binary_semaphor_handle)&#xa;    {&#xa;        RTT_ELOG_INFO(&quot;binary_semaphor_handle create err &quot;);&#xa;        while(1);&#xa;    }&#xa;    if((pdPASS == xSemaphoreGive(binary_semaphor_handle)))&#xa;    {&#xa;        RTT_ELOG_INFO(&quot;give ok&quot;);&#xa;    }" style="text;whiteSpace=wrap;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="2497.998931361608" y="357.0009814453125" width="462" height="152" as="geometry" />
        </mxCell>
        <mxCell id="hvT5LnOeasCK2AgFjy0b-18" value="if( pdPASS != xSemaphoreTake(binary_semaphor_handle, 0) )&#xa;        {&#xa;            RTT_ELOG_INFO(&quot;binary take err&quot;);&#xa;        }&#xa;        else &#xa;        {&#xa;            RTT_ELOG_INFO(&quot;binary take ok&quot;);&#xa;        }" style="text;whiteSpace=wrap;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="2519.9985714285717" y="521.0024100167414" width="440" height="137" as="geometry" />
        </mxCell>
        <mxCell id="hvT5LnOeasCK2AgFjy0b-19" value="&lt;font face=&quot;Maple Mono NF CN&quot;&gt;默认创建完的时候,内部的信号量都是为0的,除非你自己添加，&lt;/font&gt;&lt;div&gt;&lt;font face=&quot;Maple Mono NF CN&quot;&gt;主要是take-&amp;gt;获得&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Maple Mono NF CN&quot;&gt;give-&amp;gt;生产&lt;/font&gt;&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="2484" y="754" width="725" height="272" as="geometry" />
        </mxCell>
        <mxCell id="hvT5LnOeasCK2AgFjy0b-20" value="if((pdPASS == xSemaphoreGive(count_semaphor_handle)))&#xa;        {&#xa;            RTT_ELOG_INFO(&quot;give ok&quot;);&#xa;        }" style="text;whiteSpace=wrap;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="2484.0014285714287" y="680.0009814453125" width="411" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="lfelndMtFt3gQzKgF25G" name="堆栈和段">
    <mxGraphModel dx="1362" dy="1063" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-1" value="STACK-0x20000a80" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-2" value="0x800" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-3" value="__initial_sp-0x20001280" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="60" y="230" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-5" value="在map文件里面可以找到这2个符号，STACK是栈底部&lt;div&gt;__initial_sp这个是栈顶部，大小刚好是.s文件分配的&lt;/div&gt;&lt;div&gt;在ARM中栈空间是向下生长的，&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="220" y="70" width="450" height="130" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-6" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="60" y="310.00000000000006" width="268" height="423.68" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-7" value="初始化栈空间0x800填充5A" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="328" y="310" width="450" height="130" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-8" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="60" y="733.68" width="380" height="88.54" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-9" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry x="60" y="823.68" width="310" height="426.26" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-10" value="程序运行了一段时间后有了栈开销&lt;div&gt;从高地址一直覆盖到低地址，从adress来看就能很清楚的理解了。&lt;/div&gt;&lt;div&gt;arm的栈空间是从高一直填充到低地址值，这里我们就很清楚的知道了&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="328" y="830" width="450" height="130" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-11" value=".data段&lt;div&gt;存放内容,初始化的全局变量和初始化的静态变量如下&lt;/div&gt;&lt;div&gt;int a = 10；&lt;/div&gt;&lt;div&gt;static int c = 20；&lt;/div&gt;&lt;div&gt;存储特点：占用2个空间flash（rom）和ram&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry y="1520" width="400" height="140" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-12" value=".bss段&lt;div&gt;存放内容,没有显示的初始化的全局变量或初始化为0的全局变量和静态变量如下：&lt;/div&gt;&lt;div&gt;int a；&lt;/div&gt;&lt;div&gt;static int c = 0；&lt;/div&gt;&lt;div&gt;存储特点：占用1个空间ram&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry y="1660" width="400" height="140" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-13" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry y="1810" width="720" height="85.7" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-14" value="常见的section类型&lt;div&gt;.text 可执行代码-void func（void），const uint8_t a&amp;nbsp; 存放位置:FLASH 特点：只会读取 程序运行不会改变&lt;/div&gt;&lt;div&gt;.rodata const 变量&amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt; &lt;/span&gt;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;存放位置:FLASH 特点：只会读取&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.data 已经初始化并且是非0的全局变量或静态变量 &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; 存放位置:RAM 初值保存在FLASH中，运行时搬运到RAM,占空间2个地方RAM和flash&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.bss 未初始化的全局变量和静态变量或初始化为0 &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp;&amp;nbsp;存放位置:RAM&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;STACK&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;栈空间&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; 存放位置:RAM 特点高地址向下生长大小固定，由.S文件修改&lt;/span&gt;&lt;/div&gt;&lt;div&gt;HEAP&amp;nbsp; &amp;nbsp; 堆空间&amp;nbsp; &amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; 存放位置:RAM 可选大小固定 由.S文件修改，动态的内存分配MALLOC&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;align=left;" vertex="1" parent="1">
          <mxGeometry y="2350" width="820" height="140" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-15" value=".data" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry y="2200" width="130" height="90" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-16" value=".bss" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="130" y="2200" width="130" height="90" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-17" value="堆" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="260" y="2200" width="130" height="90" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-18" value="栈" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="1">
          <mxGeometry x="390" y="2200" width="130" height="90" as="geometry" />
        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-19" value="" style="edgeStyle=none;orthogonalLoop=1;jettySize=auto;html=1;rounded=0;startSize=14;endArrow=open;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;curved=1;entryX=0;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" target="MMZR0ORwyoNjBQBUhfBw-15">
