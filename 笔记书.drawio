        </mxCell>
        <mxCell id="FO6a5jXskNcYPXz5xM0C-46" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;实际的入栈操作&lt;/h1&gt;&lt;div&gt;以按键中断为实例来分析以上寄存器&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;overflow=hidden;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontFamily=Lucida Console;fontSize=15;align=left;fontStyle=1;labelBorderColor=none;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="9.47" y="3385.82" width="314.96" height="78.74" as="geometry" />
        </mxCell>
        <mxCell id="WjLulF5J0EHZ38Adze7c-2" value="" style="edgeStyle=none;curved=1;rounded=0;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#788AA3;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=#46495D;startSize=8;endSize=8;fillColor=#B2C9AB;" parent="1" source="z52lqgMbprJoOdOdIxaz-2" target="z52lqgMbprJoOdOdIxaz-8" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="z52lqgMbprJoOdOdIxaz-2" value="NVIC界面&lt;div&gt;可以看出EXTILINE-4已经使能也触发了&lt;/div&gt;&lt;div&gt;E-ENABLE&lt;/div&gt;&lt;div&gt;A-ACTIVE&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=15;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontFamily=Lucida Console;fontStyle=1;labelBorderColor=none;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="9.470000000000008" y="4291.33" width="314.96" height="118.10999999999999" as="geometry" />
        </mxCell>
        <mxCell id="WjLulF5J0EHZ38Adze7c-1" value="" style="edgeStyle=none;curved=1;rounded=0;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#788AA3;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=#46495D;startSize=8;endSize=8;fillColor=#B2C9AB;" parent="1" source="z52lqgMbprJoOdOdIxaz-3" target="z52lqgMbprJoOdOdIxaz-2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="z52lqgMbprJoOdOdIxaz-3" value="这个时候我们的CPU已经进入&lt;div&gt;异常模式，开始处理异常了&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=15;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontFamily=Lucida Console;fontStyle=1;labelBorderColor=none;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="9.47" y="4173.22" width="236.21999999999997" height="78.74" as="geometry" />
        </mxCell>
        <mxCell id="z52lqgMbprJoOdOdIxaz-5" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=none;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;rounded=0;sketch=1;curveFitting=1;jiggle=2;imageBackground=none;imageBorder=default;fillColor=#B2C9AB;strokeColor=#788AA3;fontColor=#46495D;fontFamily=Lucida Console;fontSize=15;align=left;fontStyle=1;labelBorderColor=none;" parent="1" vertex="1">
          <mxGeometry x="9.47" y="3503.93" width="787.4" height="669.29" as="geometry" />
        </mxCell>
        <mxCell id="WjLulF5J0EHZ38Adze7c-3" value="" style="edgeStyle=none;curved=1;rounded=0;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#788AA3;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=#46495D;startSize=8;endSize=8;fillColor=#B2C9AB;" parent="1" source="z52lqgMbprJoOdOdIxaz-8" target="z52lqgMbprJoOdOdIxaz-11" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="z52lqgMbprJoOdOdIxaz-8" value="其中LR这个寄存器告诉我们&lt;div&gt;此时处于异常模式的并且接下来我们要返回线程，主栈。&lt;/div&gt;&lt;div&gt;因为没有使用操作系统，所以是返回主栈&lt;/div&gt;&lt;div&gt;0xFFFFFFE9-&amp;gt;BIN-&amp;gt;11111111111111111111111111101001&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=15;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontFamily=Lucida Console;fontStyle=1;labelBorderColor=none;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="9.469999999999954" y="4448.8099999999995" width="472.43999999999994" height="118.10999999999999" as="geometry" />
        </mxCell>
        <mxCell id="z52lqgMbprJoOdOdIxaz-9" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=none;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;rounded=0;sketch=1;curveFitting=1;jiggle=2;imageBorder=default;fillColor=#B2C9AB;strokeColor=#788AA3;fontColor=#46495D;fontFamily=Lucida Console;fontSize=15;align=left;fontStyle=1;labelBorderColor=none;imageBackground=none;" parent="1" vertex="1">
          <mxGeometry x="363.8" y="3149.6" width="433.07" height="314.96" as="geometry" />
        </mxCell>
        <mxCell id="z52lqgMbprJoOdOdIxaz-11" value="此时就按照顺序把&lt;div&gt;R0-R3&lt;/div&gt;&lt;div&gt;R12,R14&lt;/div&gt;&lt;div&gt;R15压入栈里面也就是内存&lt;/div&gt;&lt;div&gt;SP指针-&amp;gt;0x20001218&lt;/div&gt;&lt;div&gt;对照内存图，可以看出MCU已经做好了上下文保存&lt;/div&gt;&lt;div&gt;那么就入栈成功了&lt;/div&gt;&lt;div&gt;因为栈里面的数据和我们栈里面的数据对应上了&lt;/div&gt;&lt;div&gt;这就是异常触发时：压栈的原理和过程&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=15;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontFamily=Lucida Console;fontStyle=1;labelBorderColor=none;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="9.47" y="4606.289999999999" width="354.33" height="196.85" as="geometry" />
        </mxCell>
        <mxCell id="petsUX6msrf6myzQr_2o-2" value="&lt;div&gt;RTOS的上下切换,其实和这个CPU异常是足足相关的&lt;/div&gt;&lt;div&gt;在RTOS里面切换任务是通过,xPortPendSVHandler&lt;/div&gt;&lt;div&gt;这个函数来进行切换的,其实就是一个异常,所以在进入异常的时候,&lt;/div&gt;&lt;div&gt;会把R0-R3 R12 R14 R15 SP指针来进行入栈,然后在通过&lt;/div&gt;&lt;div&gt;栈指针来进行出栈,放到对应的寄存器里面,然后随即切换到另外一个任务.&lt;/div&gt;&lt;div&gt;所以说为什么每一个任务都需要分配自己单独的栈空间,就是如此.&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=15;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontFamily=Lucida Console;fontStyle=1;labelBorderColor=none;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="9.47" y="4881.879999999999" width="511.80999999999995" height="118.10999999999999" as="geometry" />
        </mxCell>
        <mxCell id="petsUX6msrf6myzQr_2o-3" value="程序寄存器" style="rounded=0;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry x="9.47" y="5078.73" width="196.85" height="39.37" as="geometry" />
        </mxCell>
