        <mxCell id="lRMUmvbayZdvGjP5ZWLq-30" value="队列的基本常用API-任务到任务&lt;div&gt;&lt;div&gt;&lt;span style=&quot;mso-spacerun:&#39;yes&#39;;font-size:10.4276pt;font-family:&#39;Consolas&#39;;color:rgb(77,77,76);&quot;&gt;QueueHandle_t &lt;/span&gt;&lt;span style=&quot;mso-spacerun:&#39;yes&#39;;font-size:10.4276pt;font-family:&#39;Consolas&#39;;color:rgb(66,113,174);&quot;&gt;xQueueCreate&lt;/span&gt;&lt;span style=&quot;mso-spacerun:&#39;yes&#39;;font-size:10.4276pt;font-family:&#39;Consolas&#39;;color:rgb(245,135,31);&quot;&gt;( UBaseType_t uxQueueLength, UBaseType_t uxItemSize )&lt;/span&gt;&lt;span style=&quot;mso-spacerun:&#39;yes&#39;;font-size:10.4276pt;font-family:&#39;Consolas&#39;;color:rgb(77,77,76);&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;mso-spacerun:&#39;yes&#39;;font-size:10.4276pt;font-family:&#39;Consolas&#39;;color:rgb(77,77,76);&quot;&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt;&quot;&gt;BaseType_t &lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(66, 113, 174);&quot;&gt;xQueueSendToFront&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt;( QueueHandle_t xQueue,&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(137, 89, 168);&quot;&gt;const void&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; * pvItemToQueue,&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; TickType_t xTicksToWait )&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt;&quot;&gt;BaseType_t &lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(66, 113, 174);&quot;&gt;xQueueSendToBack&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt;( QueueHandle_t xQueue,&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(137, 89, 168);&quot;&gt;const void&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; * pvItemToQueue,&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; TickType_t xTicksToWait )&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt;&quot;&gt;BaseType_t &lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(66, 113, 174);&quot;&gt;xQueueReceive&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt;( QueueHandle_t xQueue,&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(137, 89, 168);&quot;&gt;void&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; * &lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(137, 89, 168);&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; pvBuffer,&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt; TickType_t xTicksToWait )&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10.4276pt;&quot;&gt;UBaseType_t &lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(66, 113, 174);&quot;&gt;uxQueueMessagesWaiting&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt; color: rgb(245, 135, 31);&quot;&gt;( QueueHandle_t xQueue )&lt;/span&gt;&lt;span style=&quot;font-size: 10.4276pt;&quot;&gt;;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
