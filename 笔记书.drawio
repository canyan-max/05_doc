        </mxCell>
        <mxCell id="ncrBoCA1mMu0P0deR8o_-9" value="如下面这种功能.,&lt;span style=&quot;color: rgb(156, 220, 254); background-color: rgb(31, 31, 31); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 16px; white-space-collapse: preserve;&quot;&gt;xHigherPriorityTaskWokenByPost 这个值取得要求是PDFAlse,因为PENSV优先级很低.&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=20;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" parent="1" vertex="1">
          <mxGeometry y="1560" width="819" height="39" as="geometry" />
        </mxCell>
        <mxCell id="U0-nq_Ud3s2oBGpxeMeg-1" value="&lt;font style=&quot;font-size: 21px;&quot;&gt;关于2级指针传递参数的一些说明&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry y="1944" width="817" height="51" as="geometry" />
        </mxCell>
        <mxCell id="U0-nq_Ud3s2oBGpxeMeg-2" value="static led_handler_status_t queue_create(uint32_t const item_num, \&#xa;                                         uint32_t const item_size,&#xa;                                         void **  const queue_handler)&#xa;{&#xa;    led_handler_status_t ret = LED_HANDLER_OK;&#xa;    &#xa;    if(NULL == queue_handler)&#xa;    {&#xa;        RTT_ELOG_INFO(&quot;queue create para err&quot;,HAL_GetTick());&#xa;        ret = LED_HANDLER_PARA_ERR;&#xa;        return ret;&#xa;    }&#xa;    &#xa;    // to create the queue and get the queue handler   &#xa;    QueueHandle_t temp_queue = NULL;&#xa;    RTT_ELOG_INFO(&quot;temp_queue  before [%p]&quot;, \&#xa;    temp_queue);&#xa;    RTT_ELOG_INFO(&quot;p2  before [%p]&quot;, \&#xa;    p2);&#xa;    temp_queue = xQueueCreate(item_num, item_size);&#xa;    if(NULL == temp_queue)&#xa;    {&#xa;        RTT_ELOG_INFO(&quot;queue create err&quot;,HAL_GetTick());&#xa;        ret = LED_HANDLER_ERROR;&#xa;        return ret;&#xa;    }&#xa;    RTT_ELOG_INFO(&quot;temp_queue  after [%p]&quot;, \&#xa;    temp_queue);&#xa;    // create queue is successfull&#xa;    *queue_handler = temp_queue;&#xa;    return ret;   &#xa;}" style="text;whiteSpace=wrap;fontFamily=Lucida Console;fontSize=19;fontStyle=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="2" y="1995" width="815" height="741" as="geometry" />
        </mxCell>
        <mxCell id="U0-nq_Ud3s2oBGpxeMeg-3" value="示例:&#xa;queue_create( 1, 1,&amp;p2);&#xa;假设 temp_queue 在函数内申请成功后的内存是0x2000015;&#xa;经过这个函数后queue_create( 1, 1,&amp;p2);&#xa;p2 = 0x2000015;&#xa;队列准0拷贝也是和下面的原理差不多&#xa;流程解释如下.&#xa;&#xa;" style="text;whiteSpace=wrap;fontFamily=Lucida Console;fontSize=20;fontStyle=1" parent="1" vertex="1">
