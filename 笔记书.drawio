        <mxCell id="-7LLduaztnEb4O2HBOc--5" value="2" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
