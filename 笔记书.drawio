  <diagram id="aESpygJyv2H9ImVJaQx8" name="驱动专题找对象">
    <mxGraphModel dx="1941" dy="1346" grid="1" gridSize="20" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="0O3NtGSBY4uUvOIE41jl-5" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;&lt;p&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;1.1.1&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;首先归类写的东西有什么特性&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;line-height: 100%;&quot;&gt;例如：LED灯，亮和灭，翻转，翻转时长，翻转次数&lt;/span&gt;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;line-height: 100%; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;向这一类就可以直接归结为operation ，就是操作层面&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry y="180" width="820" height="120" as="geometry" />
        </mxCell>
        <mxCell id="0PDhfY9BZxWfwebPEP7v-1" value="&lt;p style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;1.1.2 需要对外实现功能实现的接口&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry y="300" width="820" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Mmmk4_VTn8UP0J9DBHMf-1" value="&lt;p style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;* 最主要的能力是要学会找对象，找出相应的共同点，可以使得代码可以复用，不用一改就全都要改，做好隔离&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;* 改一层代码不需要修改另外一层的代码，这样就可以很好的解除耦合&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry y="380" width="720" height="100" as="geometry" />
        </mxCell>
        <mxCell id="Mmmk4_VTn8UP0J9DBHMf-2" value="&lt;p style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;1.2&amp;nbsp;以LED为对象进行抽象的过程和实操&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry y="500" width="820" height="80" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-1" value="&lt;p style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;driver的对象,是具体实现的类,如:操作的亮和灭.怎么亮怎么灭.这种实际的实现功能,在driver的驱动里面.&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry y="600" width="820" height="80" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-3" value="LED1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry y="740" width="60" height="40" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-2" value="" style="triangle;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="80" y="740" width="20" height="40" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-8" value="" style="endArrow=none;html=1;rounded=0;startSize=14;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;curved=1;" parent="1" edge="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="70" y="759.5" as="sourcePoint" />
            <mxPoint x="80" y="760" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-9" value="LED-ON&lt;div&gt;LED-OFF&lt;/div&gt;&lt;div&gt;LED-TOG&lt;/div&gt;&lt;div&gt;具体的functions&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="174" y="780" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-10" value="控制参数&lt;div&gt;1.ONOFF周期&lt;/div&gt;&lt;div&gt;2.亮灭次数&lt;/div&gt;&lt;div&gt;3.持续多久&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="174" y="680" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-11" value="对外提供,控制函数的API" style="text;strokeColor=none;fillColor=none;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="354" y="758" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-12" value="&lt;p style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;在这个driver对象里面的操作是最纯净的,只关心具体的实现动作,其他一概不管,就是一个大头兵.等待上层的命令让你开门就开门,让其闪烁就闪烁.接收到命令能够正常动作就可以,下方有一个普通的结构体示例&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry y="860" width="820" height="88" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-13" value="&lt;p style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: rgb(255, 255, 255);&quot;&gt;handler对象:handler就更加的抽象一点,他需要管理下方的driver设备,并且和上层的应用进行联系.所以需要的接口比较多.同时还要能记住下方成员的个数&lt;/span&gt;&lt;/p&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="4" y="1220" width="820" height="80" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-18" value="" style="triangle;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="100" y="1460" width="40" height="40" as="geometry" />
        </mxCell>
        <mxCell id="QZdwNjX23LQ9dl98x-IT-22" value="" style="endArrow=none;html=1;rounded=0;startSize=14;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;curved=1;" parent="1" edge="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="80" y="1480" as="sourcePoint" />
            <mxPoint x="160" y="1480" as="targetPoint" />
