        </mxCell>
        <mxCell id="K4j-HMJ9ixGcpVl9BwBr-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;向量表&lt;/h1&gt;&lt;p&gt;什么是向量表?&lt;/p&gt;&lt;p&gt;1.向量表的意思就是把前面的所说的或者MCU在出厂的时候，规划了很多不同段的地址&lt;/p&gt;&lt;p&gt;程序跑MAIN程序的地址是0x80000这些，&lt;/p&gt;&lt;p&gt;都是由厂家弄好的。其实就是提供了一个地址如果发生了对应的错误或者中断，会跳转到指定的地址。&lt;/p&gt;&lt;p&gt;2.这些都是MCU内核相关，他们存在优先级最高是-3，分为可以配置类型和不可配置类型。&lt;/p&gt;&lt;p&gt;3.可以理解为每次向量地址就是一个函数，每一个向量地址的大小是4字节-指针大小。&lt;/p&gt;" style="text;html=1;overflow=hidden;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fillColor=#B2C9AB;strokeColor=#788AA3;fontFamily=Lucida Console;fontSize=15;align=left;fontStyle=1;labelBorderColor=none;verticalAlign=top;fontColor=#46495D;" parent="1" vertex="1">
          <mxGeometry x="9.47" y="1496.06" width="810.53" height="273.94" as="geometry" />
        </mxCell>
        <mxCell id="FO6a5jXskNcYPXz5xM0C-2" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;进入异常的流程&lt;/h1&gt;" style="text;html=1;overflow=hidden;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontFamily=Lucida Console;fontSize=15;align=left;fontStyle=1;labelBorderColor=none;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="9.47" y="2362.2" width="236.22" height="39.37" as="geometry" />
        </mxCell>
        <mxCell id="FO6a5jXskNcYPXz5xM0C-3" value="入栈" style="shape=step;perimeter=stepPerimeter;html=1;fixedSize=1;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fillColor=#B2C9AB;strokeColor=#788AA3;fontColor=#46495D;fontFamily=Lucida Console;fontSize=15;align=center;fontStyle=1;labelBorderColor=none;verticalAlign=top;" parent="1" vertex="1">
          <mxGeometry x="9.47" y="2480.31" width="118.10999999999999" height="39.37" as="geometry" />
        </mxCell>
        <mxCell id="FO6a5jXskNcYPXz5xM0C-4" value="被打断的程序当前的寄存器值保存到栈中（0x20000）这个地址内&lt;div&gt;当CPU处理完异常之后，就继续恢复到之前运行的程序&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=15;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontFamily=Lucida Console;fontStyle=1;labelBorderColor=none;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="9.469999999999972" y="2401.5699999999997" width="472.43999999999994" height="78.74" as="geometry" />
        </mxCell>
