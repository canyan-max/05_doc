        <mxCell id="U0-nq_Ud3s2oBGpxeMeg-35" value="&lt;span style=&quot;text-align: left;&quot;&gt;0x200030&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="610" y="3256.5" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="U0-nq_Ud3s2oBGpxeMeg-36" value="&lt;span style=&quot;text-align: left;&quot;&gt;0x180001&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="21" y="3249" width="152" height="95" as="geometry" />
        </mxCell>
        <mxCell id="U0-nq_Ud3s2oBGpxeMeg-44" value="函数内赋值过程" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="294" y="3914" width="114" height="38" as="geometry" />
        </mxCell>
        <mxCell id="U0-nq_Ud3s2oBGpxeMeg-47" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.477;entryY=0.023;entryDx=0;entryDy=0;entryPerimeter=0;startSize=14;endArrow=open;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;" parent="1" source="U0-nq_Ud3s2oBGpxeMeg-44" target="U0-nq_Ud3s2oBGpxeMeg-17" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="U0-nq_Ud3s2oBGpxeMeg-48" value="示例:&#xa;通过以上流程就知道为什么形参需要写成2级指针的形式.如果还不够透彻下方还有示例代码,在这个demo之下,一下就秒了,简而言之就是你是需要修改指针所指向的值,那么形参必然要高于你当前指针的等级,你才可以解引用,修改到位.&#xa;&#xa;int a = 10 ;&#xa;int b = 20 ;&#xa;void swap(int a , int b)&#xa;{&#xa;int c = b;  &#xa;b=a;&#xa;a=c;&#xa;}&#xa;{&#xa;    swap(a,b);&#xa;    printf(&quot;a =%d , b=%d&quot;,a,b)&#xa;    a = 10 b = 20&#xa;}&#xa;&#xa;&#xa;void swap2(int *a , int *b)&#xa;{&#xa;      int c = *b;  &#xa;*b=*a;&#xa;*a=c;    &#xa;}&#xa;&#xa;&#xa;{&#xa;    swap2(&amp;a,&amp;b);&#xa;    printf(&quot;a =%d , b=%d&quot;,a,b)&#xa;    a = 20 b = 10&#xa;}" style="text;whiteSpace=wrap;fontFamily=Lucida Console;fontSize=20;fontStyle=1" parent="1" vertex="1">
          <mxGeometry x="4.5" y="4636" width="779" height="836" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
