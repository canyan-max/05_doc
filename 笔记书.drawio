        <mxCell id="-7LLduaztnEb4O2HBOc--6" value="3" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="210" y="-1079" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--7" value="4" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="280" y="-1079" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--8" value="5" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="350" y="-1079" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--9" value="6" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="420" y="-1079" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--10" value="7" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="490" y="-1079" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--11" value="8" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="560" y="-1079" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--12" value="9" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="630" y="-1079" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--14" value="" style="edgeStyle=none;orthogonalLoop=1;jettySize=auto;html=1;rounded=1;hachureGap=4;fontFamily=Lucida Console;fontSize=16;startSize=14;endArrow=open;endSize=14;sourcePerimeterSpacing=8;targetPerimeterSpacing=8;curved=1;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;fontColor=default;sketch=1;curveFitting=1;jiggle=2;" parent="1" edge="1">
          <mxGeometry width="140" relative="1" as="geometry">
            <mxPoint x="389.92" y="-939" as="sourcePoint" />
            <mxPoint x="389.5" y="-999" as="targetPoint" />
            <Array as="points" />
          </mxGeometry>
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--16" value="&lt;div&gt;环形缓冲区，判断满和空的条件如下：&lt;/div&gt;&lt;div&gt;第一种：&lt;/div&gt;环形BUFF的判断空条件，头==尾&lt;div&gt;环形BUFF的判断满条件，（头+1）%BUFF_LENTH == 尾&lt;/div&gt;&lt;div&gt;这种方法他会空掉一个格子，例如BUFF的长度是100 但是实际可用空间是99&lt;/div&gt;&lt;div&gt;第二种：&lt;/div&gt;&lt;div&gt;增加2个记次变量&amp;nbsp; &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;head of count&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;tail of count&lt;/div&gt;&lt;div&gt;这种方法的空间利用率是100，不会去空一个格子。那么把数据打入BUFF里面的操作是：&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;出BUF&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;*p_data = p_circlebuf-&amp;gt;p_buff[(p_circlebuf-&amp;gt;tail) % p_circlebuf-&amp;gt;buff_lenth];&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; p_circlebuf-&amp;gt;tail++;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;加入buff&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; p_circlebuf-&amp;gt;p_buff[(p_circlebuf-&amp;gt;head)%p_circlebuf-&amp;gt;buff_lenth] = data;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; p_circlebuf-&amp;gt;head++;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;html=1;align=left;verticalAlign=middle;rounded=1;fontSize=20;fontFamily=Lucida Console;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry y="-840" width="785" height="470" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--18" value="环形BUFF，可以配合串口DMA中断来使用，" style="text;strokeColor=none;fillColor=none;html=1;align=left;verticalAlign=middle;rounded=1;fontSize=20;fontFamily=Lucida Console;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry y="-1169" width="420" height="80" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--21" value="&lt;p&gt;以STM32-H7为示例，如果开DMA-循环模式和串口的IDLE中断，不管是DMA半满全满,还是IDLE中断他们调用的都是-&amp;gt;HAL_UARTEx_RxEventCallback&lt;br&gt;所以我们可以通过(huart-&amp;gt;RxEventType)来区分本次进入中断的是什么类型&lt;br&gt;HAL_UART_RXEVENT_HT&lt;br&gt;HAL_UART_RXEVENT_TC&lt;br&gt;HAL_UART_RXEVENT_IDLE&lt;br&gt;DMA循环模式和DMA的noamal模式，&lt;br&gt;这两个模式的区别主要在于，是否需要重新开启。会不会自动覆盖数据&lt;br&gt;长度都是10个的情况下，都不考虑重新开启/&lt;br&gt;normal mode ：&lt;br&gt;我发送11个 那么他只能收到10个，&lt;br&gt;circle mode ：&lt;br&gt;最后一个数据会覆盖第一个数据&lt;/p&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=1;fontSize=20;fontFamily=Lucida Console;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry y="-340" width="705" height="540" as="geometry" />
        </mxCell>
        <mxCell id="-7LLduaztnEb4O2HBOc--22" value="配合DMA来使用环形BUFFER的时候，需要做一个小的算法偏移来操作环形BUF的头部指针&lt;div&gt;1.算法思路&lt;/div&gt;&lt;div&gt;DMA发生半满中断：&lt;/div&gt;&lt;div&gt;当前头理论位置-&amp;gt;(buff_lenth / 2) -1&amp;nbsp;&lt;/div&gt;&lt;div&gt;在发生半满中断时:此时的长度就是BUFF的长度的一半,软件上采用数组的形式,所以需要-1,来计算出当前头指针的位置.&lt;/div&gt;&lt;div&gt;当前头实际位置:环形BUFF-&amp;gt;HEAD实际位置 %&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(buff_lenth / 2)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;头指针实际偏移位置:&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;当前头理论位置 -&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;当前头实际位置&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;示例计算:&lt;/div&gt;&lt;div&gt;假设当前环形BUFF头位置 为0 发生DMA半满中断&lt;/div&gt;&lt;div&gt;当前头理论位置:10 / 2 -1 = 4;&lt;/div&gt;&lt;div&gt;头指针实际偏移位置: 4 - 0 = 4;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;假设当前环形BUFF头位置 为1 发生DMA半满中断&lt;/div&gt;&lt;div&gt;当前头理论位置:10 / 2 -1 = 4;&lt;/div&gt;&lt;div&gt;头指针实际偏移位置: 4 - 1 = 3;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=1;fontSize=20;fontFamily=Lucida Console;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="5" y="280" width="705" height="510" as="geometry" />
        </mxCell>
        <mxCell id="Hp5NhEuirAhFPiXnxjF6-14" value="0" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="2.5" y="758" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Hp5NhEuirAhFPiXnxjF6-15" value="1" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="72.5" y="758" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Hp5NhEuirAhFPiXnxjF6-16" value="2" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="142.5" y="758" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Hp5NhEuirAhFPiXnxjF6-17" value="3" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="212.5" y="758" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Hp5NhEuirAhFPiXnxjF6-18" value="4" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="282.5" y="758" width="70" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Hp5NhEuirAhFPiXnxjF6-19" value="5" style="rounded=1;html=1;hachureGap=4;fontFamily=Lucida Console;align=left;fontStyle=1;textShadow=0;labelBackgroundColor=none;sketch=1;curveFitting=1;jiggle=2;whiteSpace=wrap;" parent="1" vertex="1">
