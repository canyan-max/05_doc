        <mxCell id="FO6a5jXskNcYPXz5xM0C-42" value="存储器地址方向&amp;nbsp;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=#82b366;fillColor=#d5e8d4;fontSize=15;rounded=0;sketch=1;curveFitting=1;jiggle=2;labelBackgroundColor=none;fontFamily=Lucida Console;fontStyle=1;labelBorderColor=none;" parent="1" vertex="1">
