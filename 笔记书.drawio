        </mxCell>
        <mxCell id="MMZR0ORwyoNjBQBUhfBw-23" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
          <mxGeometry y="2490" width="579.36" height="270" as="geometry" />
