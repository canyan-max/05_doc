  <diagram id="s_l6SDNf43mH6flccWoR" name="SCT文件配置">
    <mxGraphModel dx="1342" dy="1287" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-1" value="&lt;font&gt;SCT的文件书写和配置&lt;/font&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=20;" parent="1" vertex="1">
          <mxGeometry width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-2" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;fontSize=20;" parent="1" vertex="1">
          <mxGeometry x="270" y="70" width="576.74" height="400" as="geometry" />
        </mxCell>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-3" value="&lt;span&gt;在魔术棒上的link目录下，取消勾选然后可以自己操作这个文件了&lt;/span&gt;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=Lucida Console;fontSize=20;" parent="1" vertex="1">
          <mxGeometry x="2.77" y="120" width="250" height="60" as="geometry" />
        </mxCell>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-5" value="1.定义变量在某个sram内，的手法" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Lucida Console;fontSize=20;" parent="1" vertex="1">
          <mxGeometry y="510" width="340" height="40" as="geometry" />
        </mxCell>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-8" value="&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;; *************************************************************&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;; *** Scatter-Loading Description File generated by uVision ***&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;; *************************************************************&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;LR_IROM1 0x08000000 0x00200000&amp;nbsp; {&amp;nbsp; &amp;nbsp; ; load region size_region&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; ER_IROM1 0x08000000 0x00200000&amp;nbsp; {&amp;nbsp; ; load address = execution address&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; &amp;nbsp;*.o (RESET, +First)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; &amp;nbsp;*(InRoot$$Sections)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; &amp;nbsp;.ANY (+RO)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; &amp;nbsp;.ANY (+XO)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; }&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; RW_IRAM1 0x20000000 0x00020000&amp;nbsp; {&amp;nbsp; ; RW data&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; &amp;nbsp;.ANY (+RW +ZI)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; }&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; RW_IRAM4 0x38000000 0x00010000&amp;nbsp; {&amp;nbsp; ; BDMA FORMAT DATA&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; &amp;nbsp;*(.bdma_buffer)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;&amp;nbsp; }&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 21px;&quot;&gt;}&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;fontFamily=Lucida Console;align=left;" parent="1" vertex="1">
          <mxGeometry x="50" y="560" width="1020" height="730" as="geometry" />
        </mxCell>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-10" value="&lt;div&gt;&lt;span style=&quot;text-align: center;&quot;&gt;1.其中LR-IROM对应的是flash的内容，&lt;/span&gt;&lt;/div&gt;2.其中RW-IRAM对应的是SRAM的内容，可以按照以上的格式来自定义区间。&lt;div&gt;但是要保证你这块空间的内容足够，例如将一个变量定义到IRAM4中，可以这么写&lt;/div&gt;&lt;div&gt;&lt;div&gt;ALIGN_32BYTES(uint8_t g_dma_save_buf[DMA_MAX_BUFF_SIZE]) \&lt;/div&gt;&lt;div&gt;__attribute__((section(&quot;.bdma_buffer&quot;))) = {0};&lt;/div&gt;&lt;/div&gt;&lt;div&gt;3.这是最简单的定义一个变量在某个区间断内，就可以这么写，编译器会帮你自动排序&lt;/div&gt;&lt;div&gt;ALIGN_32BYTES 这个是32位对其的意思，如果你这个数组是10个，那么你在按照同样&lt;/div&gt;&lt;div&gt;的形式再定义一个，理论上A数组是从0x38000000-》&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0x3800000A，但是由于你添加了&lt;/span&gt;&lt;/div&gt;&lt;div&gt;前面这个东西，那么直接第二个数组会从0x380000020开是，因为你上个数组的结尾是到&lt;/div&gt;&lt;div&gt;0x38000001F，因为你给了编译器的指令是32位对其，也就是多浪费了一些空间。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Lucida Console;fontSize=20;" parent="1" vertex="1">
          <mxGeometry x="10" y="1290" width="820" height="280" as="geometry" />
        </mxCell>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-11" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry y="1600" width="772.77" height="470" as="geometry" />
        </mxCell>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-12" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="2.77" y="2100" width="770" height="432.25" as="geometry" />
        </mxCell>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-14" value="ZI没有赋值的数据，int I = 0；&lt;div&gt;RW：就是没有给定初始值的&lt;/div&gt;&lt;div&gt;int z；&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Lucida Console;fontSize=20;" parent="1" vertex="1">
          <mxGeometry x="100" y="2430" width="340" height="90" as="geometry" />
        </mxCell>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-16" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="10" y="3204" width="670.82" height="303" as="geometry" />
        </mxCell>
        <UserObject label="__attribute__ ((used, section (&quot;mysram4.code&quot;))) &#xa;void test_func_in_sram(void)&#xa;{&#xa;    __IO uint32_t j_cmd = 0;&#xa;    for(uint32_t i = 0; i&lt;100000000;i++)&#xa;    {&#xa;        j_cmd+=1;&#xa;        &#xa;    }&#xa;}&#xa;&#xa;&#xa;__attribute__ ((used, section (&quot;mysram1.code&quot;))) &#xa;void test_func_in_sram1(void)&#xa;{&#xa;    __IO uint32_t j_cmd = 0;&#xa;    for(uint32_t i = 0; i&lt;100000000;i++)&#xa;    {&#xa;        j_cmd+=1;&#xa;        &#xa;    }&#xa;}" link="__attribute__ ((used, section (&quot;mysram4.code&quot;))) &#xa;void test_func_in_sram(void)&#xa;{&#xa;    __IO uint32_t j_cmd = 0;&#xa;    for(uint32_t i = 0; i&lt;100000000;i++)&#xa;    {&#xa;        j_cmd+=1;&#xa;        &#xa;    }&#xa;}&#xa;&#xa;&#xa;__attribute__ ((used, section (&quot;mysram1.code&quot;))) &#xa;void test_func_in_sram1(void)&#xa;{&#xa;    __IO uint32_t j_cmd = 0;&#xa;    for(uint32_t i = 0; i&lt;100000000;i++)&#xa;    {&#xa;        j_cmd+=1;&#xa;        &#xa;    }&#xa;}" id="yB9am7ZWd1Sf3quz6ZpN-18">
          <mxCell style="text;whiteSpace=wrap;fontFamily=Lucida Console;fontSize=16;" parent="1" vertex="1">
            <mxGeometry y="2700" width="715" height="470" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="这里是map文件定位表&#xa;可以看到确实被定义到指定的地址是会偏移一个+1,这是ARM架构的特性&#xa;关于THUMB CODE 地址要+1&#xa;是因为这个东西是Thumb指令集&#xa;&#xa;&#xa;test_func_in_sram1                           0x20010001   Thumb Code    46  freertos.o(mysram1.code)&#xa;    g_dma_save_buf                           0x38000000   Data          10  bsp_usart.o(.bdma_buffer)&#xa;    test_func_in_sram                        0x38008001   Thumb Code    46  freertos.o(mysram4.code)" link="test_func_in_sram1                       0x20010001   Thumb Code    46  freertos.o(mysram1.code)&#xa;    g_dma_save_buf                           0x38000000   Data          10  bsp_usart.o(.bdma_buffer)&#xa;    test_func_in_sram                        0x38008001   Thumb Code    46  freertos.o(mysram4.code)" id="yB9am7ZWd1Sf3quz6ZpN-19">
          <mxCell style="text;whiteSpace=wrap;fontFamily=Lucida Console;fontSize=20;" parent="1" vertex="1">
            <mxGeometry y="3550" width="835" height="430" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="yB9am7ZWd1Sf3quz6ZpN-20" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;以上是把函数放在指定的地方跑的方式&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;__attribute__ ((used, section (&quot;mysram4.code&quot;)))&amp;nbsp;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontFamily=Lucida Console;" parent="1" vertex="1">
          <mxGeometry x="13" y="3950" width="610" height="60" as="geometry" />
