        <mxCell id="NDV3nJjG8p2iiw-Fgma2-1" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 16px; font-weight: 400; text-align: center; text-wrap-mode: nowrap;&quot;&gt;例如说使用BDMA配合ADC3-我们需要定义特定的地址&lt;/font&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;span style=&quot;font-size: 16px; font-weight: 400; text-align: center; text-wrap-mode: nowrap; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;SRAM4这个区间.BDMA可以直接访问.&lt;/span&gt;&lt;div style=&quot;font-size: 16px; font-weight: 400; text-align: center; text-wrap-mode: nowrap;&quot;&gt;&lt;b&gt;&lt;font&gt;ALIGN_32BYTES (uint32_t adc3_data[ADC_DMA_BUFF_SIZE])&amp;nbsp;&lt;/font&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 16px; font-weight: 400; text-align: center; text-wrap-mode: nowrap;&quot;&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;__attribute__((section(&quot;.ARM.__at_0x38000000&quot;)));&lt;/b&gt;&lt;/div&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontFamily=Lucida Console;sketch=1;curveFitting=1;jiggle=2;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
